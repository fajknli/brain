#!/bin/sh
BRAIN_ROOT="$HOME/brain"
CACHE_DIR="$BRAIN_ROOT/cache"

if [ ! -f "$CACHE_DIR/meta.tsv" ]; then
    "$BRAIN_ROOT/bin/brain-index" >/dev/null 2>&1
fi

if [ "$1" = "list" ]; then
    "$BRAIN_ROOT/bin/brain-list"
    exit 0
fi

if [ -n "$1" ]; then
    "$BRAIN_ROOT/bin/brain-context" "$1"
    exit 0
fi

export BRAIN_ROOT
TAB=$(printf '\t')

PREVIEW_CMD="printf '\033[1;33m== CONTEXT ==\033[0m\n'; '$BRAIN_ROOT/bin/brain-context' {1}; printf '\n\033[1;36m== CONTENT ==\033[0m\n'; cat '$BRAIN_ROOT/{3}'"

"$BRAIN_ROOT/bin/brain-list-raw" | fzf --multi --delimiter="$TAB" \
    --with-nth=2 \
    --header="Enter:Edit | Ctrl-D:Archive | Ctrl-N:QuickNew | Ctrl-V:Clip | Alt-I:Promote | Ctrl-Y:CopyLink | Ctrl-A:Selected | Ctrl-P:Outline" \
    --preview="$PREVIEW_CMD" \
    --bind="/:clear-query" \
    --bind="ctrl-f:page-down,ctrl-b:page-up" \
    --bind="enter:execute(\${EDITOR:-vi} '$BRAIN_ROOT/{3}')" \
    --bind="ctrl-d:execute('$BRAIN_ROOT/bin/brain-archive' '$BRAIN_ROOT/{3}')+reload('$BRAIN_ROOT/bin/brain-list-raw')" \
    --bind="ctrl-n:execute('$BRAIN_ROOT/bin/brain-add')+reload('$BRAIN_ROOT/bin/brain-list-raw')+clear-query" \
    --bind="ctrl-v:execute('$BRAIN_ROOT/bin/brain-clip')+reload('$BRAIN_ROOT/bin/brain-list-raw')" \
    --bind="alt-i:execute('$BRAIN_ROOT/bin/brain-promote-latest')+reload('$BRAIN_ROOT/bin/brain-list-raw')" \
    --bind="ctrl-y:execute('$BRAIN_ROOT/bin/brain-copy-link' {1})" \
    --bind="ctrl-a:execute('$BRAIN_ROOT/bin/brain-compile-selected' {+1})" \
    --bind="ctrl-p:execute('$BRAIN_ROOT/bin/brain-compile-outlinks' {1})"
