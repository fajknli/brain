#!/bin/sh
file="$1"
[ -z "$file" ] || [ ! -f "$file" ] && exit 1

tmpfile="${file}.$$.tmp"

awk '
/^---$/ { fm++; if (fm == 2 && !f) { print "status: archived"; f = 1 } print; next }
/^status:/ && fm == 1 { sub(/.*/, "status: archived"); f = 1 }
{ print }
' "$file" > "$tmpfile"

if [ $? -eq 0 ]; then
    mv "$tmpfile" "$file"
else
    rm -f "$tmpfile"
fi

"$HOME/brain/bin/brain-index" >/dev/null 2>&1
